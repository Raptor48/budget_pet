# Railway Database URL
DATABASE_URL=postgresql://postgres:ПАРОЛЬ@хост:порт/railway

# Required: primary admin/owner credentials used by web/auth to bootstrap
# the first user on startup. Login name should be plain ASCII.
ADMIN_LOGIN=
ADMIN_PASSWORD=

# FastAPI URL (для локальной разработки)
FASTAPI_URL=http://localhost:8000

# Next.js API URL (для локальной разработки)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Next.js 15+: allow dev HMR from LAN IPs (comma-separated full origins). Example:
# NEXT_ALLOWED_DEV_ORIGINS=http://192.168.1.117:3000

# Startup DDL lock wait (seconds) for V2 migrations — raise if ALTER TABLE often times out.
# V2_DDL_TIMEOUT=120

# Comma-separated browser origins for CORS (session cookies). Example:
# CORS_ORIGINS=http://localhost:3000,https://your-app.up.railway.app
# CORS_ORIGINS=

# Plaid webhook URL — Plaid sends SYNC_UPDATES_AVAILABLE, ITEM_LOGIN_REQUIRED, PENDING_DISCONNECT etc. here.
# Must be HTTPS. Set to your FastAPI public URL + /api/plaid/webhook
# PLAID_WEBHOOK_URL=https://<your-fastapi>.up.railway.app/api/plaid/webhook

# Plaid OAuth redirect URI — required for OAuth banks (Chase, BofA, Wells Fargo, etc.) on mobile.
# Set to: https://<your-nextjs-domain>/oauth
# Register this same URI in Plaid Dashboard → API → Allowed redirect URIs.
# Leave unset in sandbox (popup OAuth works without it on desktop).
# PLAID_REDIRECT_URI=https://<your-frontend>.up.railway.app/oauth

# Plaid webhooks: leave unset in production (JWT verified). For local tunnels only:
# PLAID_SKIP_WEBHOOK_VERIFY=true

# Next.js: Plaid-style amounts in transaction lists (-$ outflow, +$ inflow). Set false/0/off to restore legacy formatting.
# NEXT_PUBLIC_PLAID_TXN_SIGNED_DISPLAY=false

# Next.js: Demo-only tools (Settings → Danger Zone → Delete Test Data button).
# Set to "true" ONLY on the demo Railway environment where Plaid runs in sandbox.
# Leave unset in production so the destructive action is hidden from real users.
# NEXT_PUBLIC_SHOW_DEMO_TOOLS=true

# Railway Environment
RAILWAY_ENVIRONMENT=production

# Plaid Bank Integration
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
# With PLAID_ENV=sandbox, sandbox transactions are included in reports/budgets/export by default.
# Set to false to hide test data while still using Plaid sandbox:
# REPORTS_INCLUDE_PLAID_SANDBOX=false
# Plaid Personal Finance Category taxonomy: v1 or v2 (default v2). See docs/plaid.md
# PLAID_PERSONAL_FINANCE_CATEGORY_VERSION=v2
# Enable investments product (requires explicit Plaid approval for production).
# Set to false if you haven't requested the investments product yet.
# PLAID_ENABLE_INVESTMENTS=false

# Per-call timeout (seconds) for synchronous Plaid SDK requests.
# Daily sync wraps each Plaid call in asyncio.wait_for so a hung
# response cannot freeze the scheduler. Default 90s.
# PLAID_SDK_TIMEOUT=90

# Symmetric Fernet key used to encrypt Plaid access_tokens at rest in
# plaid_items.access_token_encrypted (BYTEA). Without this, tokens are
# stored as plain TEXT in plaid_items.access_token — a real risk for
# anyone with DB read access (backups, replicas, dumps).
#
# Generate ONCE and store in your password manager:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# WARNING: do NOT change this key after first use. Losing the key means
# every existing Plaid item becomes unreadable and you have to re-link
# each bank from the UI. Backfill happens automatically on the first
# startup after the key is set (idempotent — see web/plaid/repo.py).
# PLAID_ENCRYPTION_KEY=

# ----------------------------------------------------------------------------
# Telegram bot (web/telegram/) — webhook mode, runs in-process with FastAPI.
# Leave all values unset to disable the bot entirely (the webhook route still
# 200s but ignores updates so Telegram does not retry forever).
# ----------------------------------------------------------------------------

# Bot token from @BotFather. Required to enable the bot.
# TELEGRAM_BOT_TOKEN=

# Secret token Telegram echoes in the X-Telegram-Bot-Api-Secret-Token header.
# Set BOTH this env and the same value via setWebhook ?secret_token=...
# Generate once: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# TELEGRAM_WEBHOOK_SECRET=

# Public webhook URL Telegram should hit. Always your FastAPI base + the path
# /api/telegram/webhook. Configure once via the helper script in docs/bot.md.
# TELEGRAM_WEBHOOK_URL=https://<your-fastapi-host>/api/telegram/webhook

# OpenAI API key — used only by the receipt OCR pipeline (gpt-4o-mini vision).
# Without this key, /receipt commands will reply with a friendly error.
# OPENAI_API_KEY=

# Price-change alert significance gate (web/notifications/producers.py).
# A recurring stream's amount wobbles for boring reasons — the bot only
# pushes a "subscription_creep" alert when a change clears EITHER floor.
# Both are read at producer-run time, so tuning these is a Railway var
# change, not a redeploy. Defaults shown.
# BOT_PRICE_CHANGE_MIN_PCT=3.0
# BOT_PRICE_CHANGE_MIN_ABS_CENTS=100
